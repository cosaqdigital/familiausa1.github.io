---
import BaseLayout from "./BaseLayout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import ChecklistCTA from "../components/ChecklistCTA.astro";
import type { SiteArticle } from "../data/allArticles";
import type { SiteCategory } from "../data/categories";
import { SITE_URL } from "../data/pilotContent";
import { truncateText } from "../utils/cardText";

interface Props {
  category: SiteCategory;
  posts: SiteArticle[];
}

const { category, posts } = Astro.props;
const canonical = category.canonical;
const hubLabels: Record<string, { title: string; description: string }> = {
  "/furacoes-na-florida.html": {
    title: "Furacões na Flórida",
    description: "Guia completo sobre temporada, preparação, evacuação, FEMA, seguros e alertas oficiais."
  }
};

function hubInfo(href: string) {
  return hubLabels[href] ?? {
    title: href.replace("/categorias/", "").replace(".html", "").replaceAll("-", " "),
    description: "Abrir guia relacionado no Familia USA 1 para comparar temas próximos."
  };
}

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: category.h1,
  description: category.description,
  url: canonical,
  inLanguage: "pt-BR",
  publisher: { "@type": "Organization", name: "FamiliaUSA1", url: SITE_URL },
  mainEntity: {
    "@type": "ItemList",
    itemListElement: posts.slice(0, 50).map((post, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: post.canonical,
      name: post.h1 || post.title
    }))
  }
};
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Inicio", item: `${SITE_URL}/` },
    { "@type": "ListItem", position: 2, name: "Categorias", item: `${SITE_URL}/categorias.html` },
    { "@type": "ListItem", position: 3, name: category.title, item: canonical }
  ]
};
const postCountText = posts.length === 1
  ? "1 conteudo relacionado, organizado para facilitar sua pesquisa e fortalecer a navegacao interna do Familia USA 1."
  : `${posts.length} conteudos relacionados, organizados para facilitar sua pesquisa e fortalecer a navegacao interna do Familia USA 1.`;
---
<BaseLayout title={`${category.h1} | FamiliaUSA1`} description={category.description} canonical={canonical} schemas={[collectionSchema, breadcrumbSchema]}>
  <header class="narrow-container article-header">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/index.html">Inicio</a>
      <span><a href="/categorias.html">Categorias</a></span>
      <span>{category.title}</span>
    </nav>
    <div class="eyebrow">Categoria</div>
    <h1>{category.h1}</h1>
    <p class="lead">{category.intro}</p>
  </header>

  <section class="container section-wide">
    <div class="section-header">
      <h2>Guias desta categoria</h2>
      <p>{postCountText}</p>
    </div>
    {posts.length > 0 ? (
      <div class="article-grid">
        {posts.map((post) => <ArticleCard article={post} microcopyLength={110} compact />)}
      </div>
    ) : (
      <div class="card category-empty-state">
        <div class="post-category">Categoria em construcao</div>
        <h3>Estamos organizando os primeiros artigos desta area.</h3>
        <p>Enquanto isso, use os hubs abaixo para navegar pelos guias permanentes relacionados ao tema.</p>
      </div>
    )}
  </section>

  {category.hubLinks?.length ? (
    <section class="container section">
      <div class="section-header">
        <h2>Continue por estes hubs</h2>
        <p>Links de apoio para comparar temas proximos antes de tomar decisoes sobre visto, cidade, dinheiro ou mudanca.</p>
      </div>
      <div class="category-grid">
        {category.hubLinks.map((href) => {
          const hub = hubInfo(href);
          return (
            <a class="card category-card" href={href}>
              <div class="category-title">{hub.title}</div>
              <p class="card-copy">{truncateText(hub.description, 90)}</p>
              <div class="post-meta">
                <span>Hub</span>
                <span class="read-more">Explorar tema →</span>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  ) : null}

  <slot />
  <ChecklistCTA />
</BaseLayout>
