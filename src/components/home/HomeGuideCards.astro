---
import type { PortalGuideCard } from "../../data/portalGuides";

interface Props {
  guides: PortalGuideCard[];
}

const { guides } = Astro.props;
---
<section class="container home-guides" aria-labelledby="guias-completos">
  <div class="section-header">
    <div class="eyebrow">Portal FamiliaUSA1</div>
    <h2 id="guias-completos">Guias completos</h2>
    <p>Comece pelos caminhos principais do portal. Cada guia organiza artigos, fontes oficiais e proximos passos para brasileiros nos Estados Unidos.</p>
  </div>

  <div class="home-guides-grid">
    {guides.map((guide) => (
      <article class="home-guide-card">
        <div class="home-guide-icon" aria-hidden="true">{guide.icon}</div>
        <div>
          <h3>{guide.title}</h3>
          <p>{guide.description}</p>
        </div>
        {guide.href ? (
          <a class="read-more" href={guide.href}>{guide.label || "Explorar guia"} -&gt;</a>
        ) : (
          <span class="home-guide-soon">Em breve</span>
        )}
      </article>
    ))}
  </div>
</section>

<style>
  .home-guides {
    margin-top: 2rem;
    margin-bottom: 2rem;
  }

  .home-guides-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .home-guide-card {
    display: flex;
    min-height: 230px;
    flex-direction: column;
    justify-content: space-between;
    border: 1px solid rgba(16, 24, 39, 0.08);
    border-radius: 22px;
    padding: 1rem;
    background:
      radial-gradient(circle at 100% 0%, rgba(242, 140, 40, 0.12), transparent 36%),
      #fff;
    box-shadow: 0 14px 34px rgba(16, 24, 39, 0.06);
  }

  .home-guide-icon {
    display: inline-grid;
    width: 2.65rem;
    height: 2.65rem;
    place-items: center;
    border-radius: 18px;
    background: #fff2db;
    font-size: 1.35rem;
  }

  .home-guide-card h3 {
    margin: 0.9rem 0 0.45rem;
    color: #101827;
    font-size: 1.05rem;
    line-height: 1.2;
  }

  .home-guide-card p {
    display: -webkit-box;
    margin: 0;
    overflow: hidden;
    color: #5b6472;
    font-size: 0.94rem;
    line-height: 1.55;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .home-guide-soon {
    width: fit-content;
    border-radius: 999px;
    padding: 0.44rem 0.7rem;
    background: #fff2db;
    color: #9a5b13;
    font-size: 0.8rem;
    font-weight: 900;
  }

  @media (max-width: 980px) {
    .home-guides-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .home-guides-grid {
      grid-template-columns: 1fr;
    }

    .home-guide-card {
      min-height: 0;
    }
  }
</style>
