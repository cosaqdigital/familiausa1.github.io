---
import { articleUrl, DEFAULT_IMAGE, SITE_URL } from "../data/pilotContent";
import type { SiteArticle } from "../data/allArticles";
import { articleCardTitle, articleMicrocopy } from "../utils/cardText";

interface Props {
  articles: SiteArticle[];
}

const { articles } = Astro.props;
const [leadArticle, ...secondaryArticles] = articles.slice(0, 3);
const leadImage = leadArticle ? imagePath(leadArticle.image) : "";

function imagePath(image?: string) {
  if (!image || image === DEFAULT_IMAGE || image.endsWith("/familiausa1-share.svg")) {
    return "";
  }

  return image.startsWith(SITE_URL) ? image.replace(SITE_URL, "") : image;
}

function formatDate(value?: string) {
  if (!value) return "";
  const [year, month, day] = value.split("-");
  return year && month && day ? `${day}/${month}/${year}` : value;
}
---

{leadArticle && (
  <section class="container featured-editorial" aria-labelledby="artigos-em-destaque">
    <div class="featured-heading">
      <div class="eyebrow">Destaque editorial</div>
      <h2 id="artigos-em-destaque">Histórias e guias que merecem atenção agora</h2>
      <p>Conteúdos novos ou estratégicos selecionados pelo Família USA 1 para ajudar brasileiros a tomar decisões mais conscientes nos Estados Unidos.</p>
    </div>

    <div class:list={["featured-layout", secondaryArticles.length === 0 && "featured-layout-single"]}>
      <article class:list={["featured-lead", "card", !leadImage && "featured-lead-no-media"]}>
        {leadImage && (
          <a class="featured-lead-media" href={articleUrl(leadArticle.slug)} aria-label={`Ler matéria: ${articleCardTitle(leadArticle)}`}>
            <img
              src={leadImage}
              alt={`Imagem da matéria em destaque: ${articleCardTitle(leadArticle)}`}
              width="960"
              height="540"
              loading="eager"
              decoding="async"
            />
          </a>
        )}

        <div class="featured-lead-copy">
          <div class="featured-kicker">{leadArticle.featuredLabel || leadArticle.category}</div>
          <h3><a href={articleUrl(leadArticle.slug)}>{articleCardTitle(leadArticle)}</a></h3>
          <p>{articleMicrocopy(leadArticle, 165)}</p>
          <div class="featured-meta">
            <span>{formatDate(leadArticle.dateModified || leadArticle.datePublished)}</span>
            <a class="button primary" href={articleUrl(leadArticle.slug)}>Ler matéria</a>
          </div>
        </div>
      </article>

      {secondaryArticles.length > 0 && (
        <div class="featured-side" aria-label="Mais artigos em destaque">
          {secondaryArticles.map((article) => (
            <article class="featured-side-card card">
              {imagePath(article.image) && (
                <a class="featured-side-media" href={articleUrl(article.slug)} aria-label={`Ler matéria: ${articleCardTitle(article)}`}>
                  <img
                    src={imagePath(article.image)}
                    alt={`Imagem do artigo: ${articleCardTitle(article)}`}
                    loading="lazy"
                    decoding="async"
                  />
                </a>
              )}
              <div>
                <div class="featured-kicker">{article.featuredLabel || article.category}</div>
                <h3><a href={articleUrl(article.slug)}>{articleCardTitle(article)}</a></h3>
                <p>{articleMicrocopy(article, 95)}</p>
                <div class="featured-meta">
                  <span>{formatDate(article.dateModified || article.datePublished)}</span>
                  <a class="read-more" href={articleUrl(article.slug)}>Ler matéria -&gt;</a>
                </div>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
)}

<style>
  .featured-editorial {
    padding-block: clamp(28px, 5vw, 64px);
  }

  .featured-heading {
    max-width: 820px;
    margin-bottom: 20px;
  }

  .featured-heading h2 {
    margin: 8px 0 10px;
    font-size: clamp(1.65rem, 3vw, 2.5rem);
    line-height: 1.05;
  }

  .featured-heading p {
    max-width: 720px;
    color: var(--muted);
  }

  .featured-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(280px, 0.85fr);
    gap: 18px;
    align-items: stretch;
  }

  .featured-layout-single {
    grid-template-columns: minmax(0, 1fr);
  }

  .featured-lead,
  .featured-side-card {
    overflow: hidden;
    border-color: rgba(234, 88, 12, 0.2);
  }

  .featured-lead {
    display: grid;
    grid-template-columns: minmax(240px, 0.92fr) minmax(0, 1.08fr);
    padding: 0;
    min-height: 330px;
    background:
      radial-gradient(circle at top left, rgba(234, 88, 12, 0.18), transparent 34%),
      linear-gradient(135deg, #fffaf1, #ffffff 55%, #fff7ed);
  }

  .featured-lead-no-media {
    grid-template-columns: 1fr;
    min-height: auto;
  }

  .featured-lead-media {
    display: block;
    min-height: 100%;
    background: #0f172a;
  }

  .featured-lead-media img,
  .featured-side-media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .featured-lead-copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(22px, 4vw, 38px);
  }

  .featured-kicker {
    width: fit-content;
    border-radius: 999px;
    background: rgba(234, 88, 12, 0.1);
    color: #9a3412;
    font-size: 0.72rem;
    font-weight: 950;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 7px 10px;
  }

  .featured-lead h3,
  .featured-side-card h3 {
    margin: 12px 0 8px;
    line-height: 1.08;
  }

  .featured-lead h3 {
    font-size: clamp(1.65rem, 3vw, 2.55rem);
  }

  .featured-lead p,
  .featured-side-card p {
    color: var(--muted);
  }

  .featured-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 18px;
    color: var(--muted);
    font-size: 0.88rem;
    font-weight: 800;
  }

  .featured-side {
    display: grid;
    gap: 14px;
  }

  .featured-side-card {
    display: grid;
    grid-template-columns: 112px minmax(0, 1fr);
    gap: 14px;
    padding: 14px;
    background: #fff;
  }

  .featured-side-media {
    overflow: hidden;
    min-height: 112px;
    border-radius: 18px;
    background: #0f172a;
  }

  .featured-side-card h3 {
    font-size: 1.05rem;
  }

  .featured-side-card p {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-size: 0.92rem;
  }

  @media (max-width: 900px) {
    .featured-layout,
    .featured-lead {
      grid-template-columns: 1fr;
    }

    .featured-lead-media {
      min-height: 250px;
    }
  }

  @media (max-width: 640px) {
    .featured-editorial {
      padding-block: 30px;
    }

    .featured-lead-media {
      min-height: 210px;
    }

    .featured-lead-copy {
      padding: 20px;
    }

    .featured-side-card {
      grid-template-columns: 92px minmax(0, 1fr);
      border-radius: 22px;
    }

    .featured-side-media {
      min-height: 92px;
      border-radius: 14px;
    }
  }
</style>
