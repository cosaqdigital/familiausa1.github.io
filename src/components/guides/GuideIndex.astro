---
import type { GuideSection } from "../../data/entrepreneurshipCluster";

interface Props {
  title?: string;
  description?: string;
  items: GuideSection[];
}

const { title = "Mapa do guia", description, items } = Astro.props;
---
<section class="guide-block" aria-labelledby="guide-index-title">
  <div class="guide-block-header">
    <p class="guide-mini">Indice inteligente</p>
    <h2 id="guide-index-title">{title}</h2>
    {description && <p>{description}</p>}
  </div>
  <div class="guide-index-grid">
    {items.map((item) => (
      <article class="guide-index-card">
        <div>
          <span class:list={["guide-status", item.status === "published" ? "is-live" : "is-soon"]}>
            {item.status === "published" ? "Disponivel" : "Em breve"}
          </span>
          <h3>{item.title}</h3>
          <p>{item.summary}</p>
        </div>
        {item.href ? (
          <a class="read-more" href={item.href}>Saiba mais -&gt;</a>
        ) : (
          <span class="guide-soon">Conteudo em planejamento</span>
        )}
      </article>
    ))}
  </div>
</section>

<style>
  .guide-block {
    margin: 2.5rem 0;
  }

  .guide-block-header {
    max-width: 820px;
    margin-bottom: 1.2rem;
  }

  .guide-mini {
    margin: 0 0 0.45rem;
    color: #c8651b;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .guide-block-header h2 {
    margin: 0;
    color: #101827;
    font-size: clamp(1.8rem, 3vw, 2.7rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
  }

  .guide-block-header p {
    color: #5b6472;
    line-height: 1.7;
  }

  .guide-index-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .guide-index-card {
    display: flex;
    min-height: 245px;
    flex-direction: column;
    justify-content: space-between;
    border: 1px solid rgba(16, 24, 39, 0.08);
    border-radius: 22px;
    padding: 1.1rem;
    background: #fff;
    box-shadow: 0 14px 36px rgba(16, 24, 39, 0.07);
  }

  .guide-index-card h3 {
    margin: 0.8rem 0 0.5rem;
    color: #101827;
    font-size: 1.05rem;
    line-height: 1.22;
  }

  .guide-index-card p {
    color: #5b6472;
    font-size: 0.95rem;
    line-height: 1.62;
  }

  .guide-status,
  .guide-soon {
    display: inline-flex;
    width: fit-content;
    border-radius: 999px;
    padding: 0.34rem 0.62rem;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .guide-status.is-live {
    background: #e9f8ef;
    color: #19613b;
  }

  .guide-status.is-soon,
  .guide-soon {
    background: #fff2db;
    color: #9a5b13;
  }

  @media (max-width: 980px) {
    .guide-index-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 620px) {
    .guide-index-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
