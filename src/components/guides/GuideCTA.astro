---
interface Props {
  title: string;
  description: string;
  primaryHref: string;
  primaryLabel: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const { title, description, primaryHref, primaryLabel, secondaryHref, secondaryLabel } = Astro.props;
---
<section class="guide-cta">
  <div>
    <p class="guide-mini">Proximo passo</p>
    <h2>{title}</h2>
    <p>{description}</p>
  </div>
  <div class="guide-cta-actions">
    <a class="button primary" href={primaryHref}>{primaryLabel}</a>
    {secondaryHref && <a class="button secondary" href={secondaryHref}>{secondaryLabel}</a>}
  </div>
</section>

<style>
  .guide-cta {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1.2rem;
    align-items: center;
    margin: 2.5rem 0;
    border-radius: 28px;
    padding: clamp(1.5rem, 3vw, 2.2rem);
    background:
      radial-gradient(circle at 100% 0%, rgba(242, 140, 40, 0.28), transparent 30%),
      linear-gradient(135deg, #101827, #172133);
    color: #fffaf1;
  }

  .guide-mini {
    margin: 0 0 0.45rem;
    color: #ffd08a;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .guide-cta h2 {
    margin: 0;
    color: #fffaf1;
    font-size: clamp(1.7rem, 3vw, 2.55rem);
  }

  .guide-cta p {
    max-width: 720px;
    color: rgba(255, 250, 241, 0.82);
    line-height: 1.7;
  }

  .guide-cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    justify-content: flex-end;
  }

  @media (max-width: 780px) {
    .guide-cta {
      grid-template-columns: 1fr;
    }

    .guide-cta-actions {
      justify-content: flex-start;
    }
  }
</style>
