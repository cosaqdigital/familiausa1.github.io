---
import ArticleCard from "../ArticleCard.astro";
import type { SiteArticle } from "../../data/allArticles";

interface Props {
  title?: string;
  description?: string;
  articles: SiteArticle[];
}

const { title = "Artigos do cluster", description, articles } = Astro.props;
---
{articles.length > 0 && (
  <section class="guide-related" aria-labelledby="guide-related-title">
    <div class="guide-related-header">
      <p class="guide-mini">Continue aprendendo</p>
      <h2 id="guide-related-title">{title}</h2>
      {description && <p>{description}</p>}
    </div>
    <div class="article-grid">
      {articles.map((article) => <ArticleCard article={article} microcopyLength={95} compact />)}
    </div>
  </section>
)}

<style>
  .guide-related {
    margin: 2.5rem 0;
  }

  .guide-mini {
    margin: 0 0 0.45rem;
    color: #c8651b;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .guide-related-header {
    max-width: 820px;
    margin-bottom: 1rem;
  }

  .guide-related-header h2 {
    margin: 0;
    color: #101827;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
  }

  .guide-related-header p {
    color: #5b6472;
    line-height: 1.7;
  }
</style>
