---
import type { GuideJourneyStep } from "../../data/entrepreneurshipCluster";

interface Props {
  previous?: GuideJourneyStep;
  next?: GuideJourneyStep;
}

const { previous, next } = Astro.props;
---
{(previous || next) && (
  <nav class="guide-next-step" aria-label="Navegacao da jornada">
    {previous && (
      <a href={previous.href || "/empreendedorismo-nos-estados-unidos.html"}>
        <span>Passo anterior</span>
        <strong>{previous.label}</strong>
      </a>
    )}
    {next && (
      <a href={next.href || "/empreendedorismo-nos-estados-unidos.html"}>
        <span>Proximo passo</span>
        <strong>{next.label}</strong>
      </a>
    )}
  </nav>
)}

<style>
  .guide-next-step {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin: 1.5rem 0;
  }

  .guide-next-step a {
    border: 1px solid rgba(16, 24, 39, 0.08);
    border-radius: 18px;
    padding: 1rem;
    background: #fffaf3;
    color: #101827;
    text-decoration: none;
  }

  .guide-next-step span {
    display: block;
    color: #c8651b;
    font-size: 0.74rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .guide-next-step strong {
    display: block;
    margin-top: 0.35rem;
    font-size: 1.05rem;
  }

  @media (max-width: 620px) {
    .guide-next-step {
      grid-template-columns: 1fr;
    }
  }
</style>
