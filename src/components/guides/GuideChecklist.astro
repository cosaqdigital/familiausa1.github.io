---
interface Props {
  title?: string;
  items: string[];
}

const { title = "Checklist rapido", items } = Astro.props;
---
<section class="guide-checklist" aria-labelledby="guide-checklist-title">
  <h2 id="guide-checklist-title">{title}</h2>
  <div class="guide-checklist-grid">
    {items.map((item) => (
      <div class="guide-check-item">
        <span aria-hidden="true">✓</span>
        <p>{item}</p>
      </div>
    ))}
  </div>
</section>

<style>
  .guide-checklist {
    margin: 2.5rem 0;
    border-radius: 28px;
    padding: clamp(1.4rem, 3vw, 2.2rem);
    background: linear-gradient(135deg, #101827, #172133);
    color: #fffaf1;
  }

  .guide-checklist h2 {
    margin: 0 0 1rem;
    color: #fffaf1;
    font-size: clamp(1.7rem, 3vw, 2.4rem);
  }

  .guide-checklist-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .guide-check-item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.7rem;
    align-items: start;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 18px;
    padding: 0.85rem;
    background: rgba(255, 255, 255, 0.08);
  }

  .guide-check-item span {
    display: inline-grid;
    width: 1.55rem;
    height: 1.55rem;
    place-items: center;
    border-radius: 999px;
    background: #f28c28;
    color: #101827;
    font-weight: 900;
  }

  .guide-check-item p {
    margin: 0;
    color: rgba(255, 250, 241, 0.88);
    line-height: 1.55;
  }

  @media (max-width: 680px) {
    .guide-checklist-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
