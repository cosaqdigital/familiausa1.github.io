---
type FaqItem = {
  question: string;
  answer: string;
};

interface Props {
  title?: string;
  items: FaqItem[];
}

const { title = "Perguntas frequentes", items } = Astro.props;
---
<section class="guide-faq" aria-labelledby="guide-faq-title">
  <h2 id="guide-faq-title">{title}</h2>
  {items.map((item) => (
    <details>
      <summary>{item.question}</summary>
      <p>{item.answer}</p>
    </details>
  ))}
</section>

<style>
  .guide-faq {
    margin: 2.5rem 0;
  }

  .guide-faq h2 {
    margin: 0 0 1rem;
    color: #101827;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
  }

  .guide-faq details {
    border: 1px solid rgba(16, 24, 39, 0.08);
    border-radius: 18px;
    margin-bottom: 0.75rem;
    padding: 1rem;
    background: #fff;
    box-shadow: 0 10px 28px rgba(16, 24, 39, 0.05);
  }

  .guide-faq summary {
    cursor: pointer;
    color: #101827;
    font-weight: 900;
  }

  .guide-faq p {
    margin-bottom: 0;
    color: #5b6472;
    line-height: 1.7;
  }
</style>
