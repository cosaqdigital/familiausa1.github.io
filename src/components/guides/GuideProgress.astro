---
import { ENTREPRENEURSHIP_HUB_PATH, ENTREPRENEURSHIP_PILLAR_PATH, entrepreneurshipJourney } from "../../data/entrepreneurshipCluster";

interface Props {
  currentSlug?: string;
}

const { currentSlug } = Astro.props;
const currentIndex = entrepreneurshipJourney.findIndex((step) => step.slug === currentSlug);
const currentStep = currentIndex >= 0 ? entrepreneurshipJourney[currentIndex] : null;
const previousStep = currentIndex > 0 ? entrepreneurshipJourney[currentIndex - 1] : null;
const nextStep = currentIndex >= 0 && currentIndex < entrepreneurshipJourney.length - 1 ? entrepreneurshipJourney[currentIndex + 1] : null;
---
<section class="entrepreneur-progress" aria-labelledby="entrepreneur-progress-title">
  <div class="progress-header">
    <p>Sua jornada empreendedora</p>
    <h2 id="entrepreneur-progress-title">Onde este artigo entra no plano</h2>
    <span>Este bloco conecta os guias do cluster para voce nao estudar cada tema solto.</span>
  </div>

  <ol class="progress-steps">
    {entrepreneurshipJourney.map((step) => (
      <li class:list={[step.slug === currentSlug && "is-current", step.status === "soon" && "is-soon"]}>
        {step.href ? (
          <a href={step.href}>
            <span>Etapa {step.step}</span>
            <strong>{step.label}</strong>
          </a>
        ) : (
          <div>
            <span>Etapa {step.step}</span>
            <strong>{step.label}</strong>
            <em>Em breve</em>
          </div>
        )}
      </li>
    ))}
  </ol>

  <div class="progress-meta">
    {currentStep && (
      <div>
        <strong>Voce esta aqui:</strong>
        <p>{currentStep.summary}</p>
      </div>
    )}
    <div class="progress-links">
      <a href={ENTREPRENEURSHIP_PILLAR_PATH}>Guia completo</a>
      <a href={ENTREPRENEURSHIP_HUB_PATH}>Hub empreendedorismo</a>
      {previousStep?.href && <a href={previousStep.href}>Passo anterior</a>}
      {nextStep?.href && <a href={nextStep.href}>Proximo passo</a>}
    </div>
  </div>
</section>

<style>
  .entrepreneur-progress {
    margin: 2rem auto;
    border: 1px solid rgba(16, 24, 39, 0.08);
    border-radius: 26px;
    padding: clamp(1.2rem, 3vw, 1.8rem);
    background: linear-gradient(135deg, #fffaf3, #f6f8fb);
    box-shadow: 0 14px 34px rgba(16, 24, 39, 0.06);
  }

  .progress-header p {
    margin: 0 0 0.35rem;
    color: #c8651b;
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .progress-header h2 {
    margin: 0;
    color: #101827;
    font-size: clamp(1.45rem, 3vw, 2rem);
  }

  .progress-header span {
    display: block;
    margin-top: 0.45rem;
    color: #5b6472;
    line-height: 1.6;
  }

  .progress-steps {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
    margin: 1.2rem 0;
    padding: 0;
    list-style: none;
  }

  .progress-steps a,
  .progress-steps div {
    display: block;
    height: 100%;
    border: 1px solid rgba(16, 24, 39, 0.08);
    border-radius: 16px;
    padding: 0.85rem;
    background: #fff;
    color: #101827;
    text-decoration: none;
  }

  .progress-steps li.is-current a,
  .progress-steps li.is-current div {
    border-color: rgba(242, 140, 40, 0.55);
    background: #fff2db;
  }

  .progress-steps li.is-soon div {
    opacity: 0.82;
  }

  .progress-steps span {
    display: block;
    color: #c8651b;
    font-size: 0.7rem;
    font-weight: 900;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .progress-steps strong {
    display: block;
    margin-top: 0.3rem;
    font-size: 0.95rem;
    line-height: 1.25;
  }

  .progress-steps em {
    display: block;
    margin-top: 0.4rem;
    color: #9a5b13;
    font-size: 0.78rem;
    font-style: normal;
    font-weight: 900;
  }

  .progress-meta {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: center;
  }

  .progress-meta p {
    margin: 0.35rem 0 0;
    color: #5b6472;
    line-height: 1.6;
  }

  .progress-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    justify-content: flex-end;
  }

  .progress-links a {
    border-radius: 999px;
    padding: 0.56rem 0.78rem;
    background: #101827;
    color: #fffaf1;
    font-size: 0.8rem;
    font-weight: 900;
    text-decoration: none;
  }

  @media (max-width: 820px) {
    .progress-steps,
    .progress-meta {
      grid-template-columns: 1fr;
    }

    .progress-links {
      justify-content: flex-start;
    }
  }
</style>
