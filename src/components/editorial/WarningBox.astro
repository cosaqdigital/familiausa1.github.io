---
interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<aside class="editorial-warning-box">
  <span class="editorial-warning-marker" aria-hidden="true">!</span>
  <div class="editorial-warning-body">
    {title && <p class="editorial-warning-title"><strong>{title}</strong></p>}
    <div class="editorial-warning-content">
      <slot />
    </div>
  </div>
</aside>

<style>
  .editorial-warning-box {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.9rem;
    width: 100%;
    max-width: 100%;
    min-width: 0;
    margin: 1.75rem 0;
    border: 1px solid rgba(168, 93, 18, 0.25);
    border-left: 0.3rem solid #a85d12;
    border-radius: 1rem;
    padding: clamp(1rem, 2.5vw, 1.25rem);
    color: #44392e;
    background: #fff7e8;
  }

  .editorial-warning-marker {
    display: inline-grid;
    width: 1.75rem;
    height: 1.75rem;
    place-items: center;
    border-radius: 50%;
    color: #fff;
    background: #8a4b0c;
    font-weight: 900;
    line-height: 1;
  }

  .editorial-warning-body {
    min-width: 0;
  }

  .editorial-warning-title {
    margin: 0 0 0.45rem;
    color: #6e3c0c;
    line-height: 1.35;
  }

  .editorial-warning-content {
    min-width: 0;
    line-height: 1.65;
    overflow-wrap: anywhere;
  }

  :global(.editorial-warning-content > :first-child) {
    margin-top: 0;
  }

  :global(.editorial-warning-content > :last-child) {
    margin-bottom: 0;
  }

  @media (max-width: 30rem) {
    .editorial-warning-box {
      grid-template-columns: 1fr;
    }
  }
</style>
