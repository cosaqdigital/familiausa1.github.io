---
interface Props {
  pros?: string[];
  cons?: string[];
  prosTitle?: string;
  consTitle?: string;
}

const {
  pros = [],
  cons = [],
  prosTitle = "Vantagens",
  consTitle = "Pontos de atenção"
} = Astro.props;

const hasBothColumns = pros.length > 0 && cons.length > 0;
---

{(pros.length > 0 || cons.length > 0) && (
  <section class:list={["editorial-pros-cons", !hasBothColumns && "editorial-pros-cons--single"]}>
    {pros.length > 0 && (
      <div class="editorial-pros-cons-column editorial-pros">
        <h3>{prosTitle}</h3>
        <ul>
          {pros.map((item) => (
            <li>
              <span aria-hidden="true">+</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    {cons.length > 0 && (
      <div class="editorial-pros-cons-column editorial-cons">
        <h3>{consTitle}</h3>
        <ul>
          {cons.map((item) => (
            <li>
              <span aria-hidden="true">−</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    )}
  </section>
)}

<style>
  .editorial-pros-cons {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    width: 100%;
    max-width: 100%;
    min-width: 0;
    margin: 1.75rem 0;
  }

  .editorial-pros-cons--single {
    grid-template-columns: minmax(0, 1fr);
  }

  .editorial-pros-cons-column {
    min-width: 0;
    border: 1px solid var(--line, rgba(30, 26, 20, 0.12));
    border-radius: 1rem;
    padding: clamp(1rem, 2.5vw, 1.25rem);
  }

  .editorial-pros {
    border-top: 0.25rem solid var(--green, #2f5c4f);
    background: #f0f7f3;
  }

  .editorial-cons {
    border-top: 0.25rem solid #a85d12;
    background: #fff7e8;
  }

  h3 {
    margin: 0 0 0.85rem;
    color: var(--ink, #171512);
    font-size: clamp(1.08rem, 2vw, 1.3rem);
    line-height: 1.3;
    overflow-wrap: anywhere;
  }

  ul {
    display: grid;
    gap: 0.65rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  li {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.65rem;
    align-items: start;
    min-width: 0;
    margin: 0;
    color: var(--ink-soft, #4c463d);
    line-height: 1.55;
    overflow-wrap: anywhere;
  }

  li > :first-child {
    display: inline-grid;
    width: 1.4rem;
    height: 1.4rem;
    place-items: center;
    border-radius: 50%;
    color: #fff;
    font-weight: 900;
    line-height: 1;
  }

  .editorial-pros li > :first-child {
    background: var(--green, #2f5c4f);
  }

  .editorial-cons li > :first-child {
    background: #8a4b0c;
  }

  @media (max-width: 42rem) {
    .editorial-pros-cons {
      grid-template-columns: 1fr;
    }
  }
</style>
