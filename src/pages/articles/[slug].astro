---
import ArticleLayout from "../../layouts/ArticleLayout.astro";
import { getRelatedLegacyArticles, legacyArticles } from "../../data/legacyArticles";

export function getStaticPaths() {
  return legacyArticles.map((article) => ({
    params: { slug: article.slug },
    props: { article, relatedPosts: getRelatedLegacyArticles(article) }
  }));
}

const { article, relatedPosts } = Astro.props;
---
<ArticleLayout article={article} relatedPosts={relatedPosts} renderFaqSection={false}>
  <Fragment set:html={article.content} />
</ArticleLayout>
