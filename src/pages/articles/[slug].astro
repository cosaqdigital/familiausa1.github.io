---
import ArticleLayout from "../../layouts/ArticleLayout.astro";
import { getRelatedMigrationArticles, migrationBatchArticles } from "../../data/migrationBatch20";

export function getStaticPaths() {
  return migrationBatchArticles.map((article) => ({
    params: { slug: article.slug },
    props: { article, relatedPosts: getRelatedMigrationArticles(article) }
  }));
}

const { article, relatedPosts } = Astro.props;
---
<ArticleLayout article={article} relatedPosts={relatedPosts} renderFaqSection={false}>
  <Fragment set:html={article.content} />
</ArticleLayout>
