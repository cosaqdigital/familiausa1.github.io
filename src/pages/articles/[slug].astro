---
import ArticleLayout from "../../layouts/ArticleLayout.astro";
import { allArticles, getRelatedArticles } from "../../data/allArticles";

export function getStaticPaths() {
  return allArticles.map((article) => ({
    params: { slug: article.slug },
    props: { article, relatedPosts: getRelatedArticles(article) }
  }));
}

const { article, relatedPosts } = Astro.props;
const MarkdownContent = article.source === "markdown" ? article.Content : null;
---
<ArticleLayout article={article} relatedPosts={relatedPosts} renderFaqSection={false}>
  {MarkdownContent ? <MarkdownContent /> : <Fragment set:html={article.content} />}
</ArticleLayout>
