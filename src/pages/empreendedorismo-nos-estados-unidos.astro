---
import BaseLayout from "../layouts/BaseLayout.astro";
import GuideHero from "../components/guides/GuideHero.astro";
import GuideSummary from "../components/guides/GuideSummary.astro";
import GuideIndex from "../components/guides/GuideIndex.astro";
import GuideChecklist from "../components/guides/GuideChecklist.astro";
import GuideOfficialSources from "../components/guides/GuideOfficialSources.astro";
import GuideTools from "../components/guides/GuideTools.astro";
import GuideDownloads from "../components/guides/GuideDownloads.astro";
import GuideFAQ from "../components/guides/GuideFAQ.astro";
import GuideCTA from "../components/guides/GuideCTA.astro";
import GuideRelatedArticles from "../components/guides/GuideRelatedArticles.astro";
import { DEFAULT_IMAGE, SITE_URL } from "../data/pilotContent";
import { getArticleBySlug } from "../data/allArticles";
import {
  ENTREPRENEURSHIP_HUB_URL,
  ENTREPRENEURSHIP_PILLAR_PATH,
  ENTREPRENEURSHIP_PILLAR_URL,
  entrepreneurshipArticleSlugs,
  entrepreneurshipFaq,
  entrepreneurshipJourney,
  officialEntrepreneurshipSources
} from "../data/entrepreneurshipCluster";

const title = "Empreendedorismo nos Estados Unidos para brasileiros | FamiliaUSA1";
const description = "Hub de empreendedorismo nos EUA para brasileiros: empresa, LLC, EIN, invoice, licencas, seguro, financas, precificacao, Google e clientes.";
const clusterArticles = entrepreneurshipArticleSlugs
  .map((slug) => getArticleBySlug(slug))
  .filter(Boolean);

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: title,
  description,
  url: ENTREPRENEURSHIP_HUB_URL,
  inLanguage: "pt-BR",
  isPartOf: { "@type": "WebSite", name: "FamiliaUSA1", url: SITE_URL },
  hasPart: clusterArticles.map((article) => ({
    "@type": "Article",
    headline: article.title,
    url: article.canonical
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Inicio", item: `${SITE_URL}/` },
    { "@type": "ListItem", position: 2, name: "Empreendedorismo nos Estados Unidos", item: ENTREPRENEURSHIP_HUB_URL }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: entrepreneurshipFaq.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: { "@type": "Answer", text: item.answer }
  }))
};
---
<BaseLayout title={title} description={description} canonical={ENTREPRENEURSHIP_HUB_URL} image={DEFAULT_IMAGE} schemas={[collectionSchema, breadcrumbSchema, faqSchema]}>
  <div class="container">
    <GuideHero
      eyebrow="Hub permanente"
      title="Empreendedorismo nos Estados Unidos para brasileiros"
      description="Um centro de navegacao para quem quer abrir, organizar, cobrar, divulgar e proteger um pequeno negocio nos EUA com mais clareza e menos improviso."
      primaryHref={ENTREPRENEURSHIP_PILLAR_PATH}
      primaryLabel="Abrir guia completo"
      secondaryHref="#artigos"
      secondaryLabel="Ver artigos publicados"
      badges={["LLC", "EIN", "Invoice", "Licencas", "Seguros", "Clientes"]}
    />

    <GuideSummary
      items={[
        { label: "Objetivo", value: "Organizar o caminho para empreender com responsabilidade nos EUA" },
        { label: "Status", value: "Primeiro hub do portal no modelo de cluster definitivo" },
        { label: "Artigos", value: `${clusterArticles.length} guias publicados e novos temas em planejamento` },
        { label: "Cuidado", value: "Nao substitui advogado, CPA, contador, orgaos oficiais ou licencas" }
      ]}
    />

    <section class="hub-intro" aria-labelledby="hub-intro-title">
      <div>
        <p class="hub-mini">Comece pela decisao certa</p>
        <h2 id="hub-intro-title">O que este hub resolve</h2>
        <p>O brasileiro que quer empreender nos EUA costuma encontrar informacoes soltas: um video sobre LLC, um post sobre EIN, uma conversa sobre ITIN, uma dica de invoice, uma promessa de abrir empresa rapido e um amigo dizendo que Sunbiz resolve tudo. Este hub organiza a jornada inteira em uma pagina so.</p>
        <p>Aqui voce encontra a pagina pilar, os artigos satelites, fontes oficiais, ferramentas uteis, checklist e proximos temas. A ideia e simples: antes de pagar por servico, registrar empresa, anunciar ou aceitar cliente, voce entende o mapa.</p>
      </div>
      <aside>
        <strong>Dica do FamiliaUSA1</strong>
        <p>Empreender e mais seguro quando voce sabe o que cada documento faz. LLC, EIN, ITIN, SSN, Registered Agent, invoice, licenca, seguro, preco e Google Business sao pecas diferentes do mesmo quebra-cabeca.</p>
      </aside>
    </section>

    <GuideIndex
      title="Cards principais da jornada"
      description="Use esta sequencia para estudar empreendedorismo como projeto, nao como atalho. Os cards publicados levam para artigos existentes; os futuros ficam marcados como em breve."
      items={entrepreneurshipJourney.map((step) => ({
        title: step.title,
        summary: step.summary,
        href: step.href,
        status: step.status
      }))}
    />

    <section id="artigos">
      <GuideRelatedArticles
        title="Ultimos artigos do cluster"
        description="Os guias publicados atacam as duvidas mais perigosas: legalizacao, SSN, Registered Agent, Sunbiz, invoice, financas, seguro, preco, Google e clientes."
        articles={clusterArticles}
      />
    </section>

    <section class="hub-panels" aria-labelledby="hub-panels-title">
      <div class="hub-panel hub-panel-strong">
        <p class="hub-mini">Guia completo</p>
        <h2 id="hub-panels-title">Leia o mapa central antes dos detalhes</h2>
        <p>A pagina pilar mostra a jornada completa: quem pode empreender, abrir empresa, LLC, corporation, EIN, SSN, ITIN, Registered Agent, invoice, banco, licencas, impostos, 1099, W-9, seguros, precificacao, Google Business, primeiros clientes e ferramentas.</p>
        <a class="button primary" href={ENTREPRENEURSHIP_PILLAR_PATH}>Abrir guia completo</a>
      </div>
      <div class="hub-panel">
        <p class="hub-mini">Mais lidos do tema</p>
        <ul>
          <li><a href="/articles/abrir-empresa-nos-eua-legaliza-minha-situacao.html">Abrir empresa legaliza minha situacao?</a></li>
          <li><a href="/articles/preciso-de-ssn-para-abrir-llc-nos-eua.html">Preciso de SSN para abrir LLC?</a></li>
          <li><a href="/articles/sunbiz-nao-e-licenca-erro-brasileiros-florida.html">Sunbiz nao e licenca na Florida</a></li>
        </ul>
      </div>
    </section>

    <GuideChecklist
      title="Checklist inicial de organizacao"
      items={[
        "Entender se voce pode trabalhar legalmente no tipo de atividade pretendida.",
        "Escolher estrutura empresarial com apoio de fonte oficial e profissional qualificado.",
        "Separar identificacao pessoal, fiscal e empresarial: SSN, ITIN e EIN.",
        "Verificar licencas antes de vender servico na Florida ou em outro estado.",
        "Criar invoice, rotina de comprovantes e controle de recebimentos.",
        "Separar conta pessoal, bookkeeping, recibos, 1099, W-9 e documentos para contador.",
        "Avaliar seguro empresarial, commercial auto, workers comp e certificado quando necessario.",
        "Precificar com base em custo real, tempo, imposto, seguro, deslocamento e margem.",
        "Montar presenca local com Google Business Profile, fotos reais e atendimento consistente.",
        "Confirmar imposto, sales tax, 1099, W-9 e bookkeeping com profissional."
      ]}
    />

    <GuideTools
      title="Ferramentas uteis para pequenos negocios"
      tools={[
        { name: "QuickBooks", description: "Organizacao financeira, invoices, categorias e relatorios." },
        { name: "Stripe", description: "Pagamentos digitais, links de cobranca e cartoes." },
        { name: "Square", description: "Pagamentos presenciais e operacao simples para servicos locais." },
        { name: "PayPal Business", description: "Cobrancas digitais e historico de recebimentos, com atencao a taxas." },
        { name: "Wise", description: "Transferencias e cambio, sem substituir orientacao fiscal." },
        { name: "Google Business Profile", description: "Presenca em Search e Maps para negocios locais." },
        { name: "Nextdoor e Yelp", description: "Descoberta local e reputacao, dependendo da cidade e nicho." },
        { name: "Planilha", description: "Controle minimo de receita, despesa, materiais, milhas e lucro." }
      ]}
    />

    <GuideDownloads
      title="Downloads e estruturas preparadas"
      items={[
        {
          title: "Checklist da mudanca para os EUA",
          description: "Material gratuito ja publicado para organizar documentos, dinheiro, moradia, escola, carro e primeiros passos.",
          href: "/checklist-mudanca-eua.html",
          label: "Baixar checklist gratuito"
        },
        {
          title: "Checklist do pequeno negocio nos EUA",
          description: "Estrutura planejada para uma proxima sprint com empresa, banco, invoice, licencas, seguro, impostos e marketing."
        }
      ]}
    />

    <GuideOfficialSources sources={officialEntrepreneurshipSources} />

    <GuideFAQ items={entrepreneurshipFaq} />

    <GuideCTA
      title="Continue aprendendo com seguranca"
      description="Depois de estudar o hub, aprofunde nos artigos satelites e confira tambem a categoria Trabalho e renda para entender rotina, autorizacao e ganhos nos EUA."
      primaryHref={ENTREPRENEURSHIP_PILLAR_PATH}
      primaryLabel="Ler guia completo"
      secondaryHref="/categorias/trabalho-renda.html"
      secondaryLabel="Ver trabalho e renda"
    />
  </div>
</BaseLayout>

<style>
  .hub-intro,
  .hub-panels {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(260px, 0.65fr);
    gap: 1rem;
    margin: 2rem 0;
  }

  .hub-intro > div,
  .hub-intro aside,
  .hub-panel {
    border: 1px solid rgba(16, 24, 39, 0.08);
    border-radius: 24px;
    padding: clamp(1.2rem, 3vw, 1.8rem);
    background: #fff;
    box-shadow: 0 14px 36px rgba(16, 24, 39, 0.06);
  }

  .hub-intro aside,
  .hub-panel-strong {
    background: #fffaf3;
  }

  .hub-mini {
    margin: 0 0 0.45rem;
    color: #c8651b;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .hub-intro h2,
  .hub-panel h2 {
    margin: 0 0 0.8rem;
    color: #101827;
    font-size: clamp(1.7rem, 3vw, 2.45rem);
    line-height: 1.05;
  }

  .hub-intro p,
  .hub-panel p {
    color: #5b6472;
    line-height: 1.72;
  }

  .hub-intro aside strong {
    color: #101827;
    font-size: 1.05rem;
  }

  .hub-panel ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .hub-panel li + li {
    margin-top: 0.75rem;
  }

  .hub-panel li a {
    color: #101827;
    font-weight: 900;
    text-decoration: none;
  }

  .hub-panel li a:hover {
    color: #c8651b;
  }

  @media (max-width: 820px) {
    .hub-intro,
    .hub-panels {
      grid-template-columns: 1fr;
    }
  }
</style>
