---
import BaseLayout from "../layouts/BaseLayout.astro";
import GuideHero from "../components/guides/GuideHero.astro";
import GuideSummary from "../components/guides/GuideSummary.astro";
import GuideOfficialSources from "../components/guides/GuideOfficialSources.astro";
import GuideCTA from "../components/guides/GuideCTA.astro";
import PillarContent from "../content/pillars/empreender-nos-estados-unidos-guia-completo.mdx";
import { DEFAULT_IMAGE, SITE_URL } from "../data/pilotContent";
import {
  ENTREPRENEURSHIP_HUB_PATH,
  ENTREPRENEURSHIP_PILLAR_URL,
  entrepreneurshipFaq,
  officialEntrepreneurshipSources
} from "../data/entrepreneurshipCluster";

const title = "Como empreender nos Estados Unidos sendo brasileiro: guia completo (2026)";
const description = "Guia completo para brasileiros empreenderem nos EUA: empresa, LLC, EIN, banco, licenças, impostos, marketing, clientes e crescimento responsável em 2026.";
const datePublished = "2026-06-26";
const dateModified = "2026-07-20";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Início", item: `${SITE_URL}/` },
    { "@type": "ListItem", position: 2, name: "Empreendedorismo nos Estados Unidos", item: `${SITE_URL}${ENTREPRENEURSHIP_HUB_PATH}` },
    { "@type": "ListItem", position: 3, name: "Guia completo para empreender nos EUA", item: ENTREPRENEURSHIP_PILLAR_URL }
  ]
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description,
  url: ENTREPRENEURSHIP_PILLAR_URL,
  datePublished,
  dateModified,
  inLanguage: "pt-BR",
  author: { "@type": "Organization", name: "FamiliaUSA1" },
  publisher: { "@type": "Organization", name: "FamiliaUSA1", url: SITE_URL },
  mainEntityOfPage: { "@type": "WebPage", "@id": ENTREPRENEURSHIP_PILLAR_URL },
  image: DEFAULT_IMAGE
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: entrepreneurshipFaq.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: { "@type": "Answer", text: item.answer }
  }))
};
---

<BaseLayout title={title} description={description} canonical={ENTREPRENEURSHIP_PILLAR_URL} image={DEFAULT_IMAGE} schemas={[breadcrumbSchema, articleSchema, faqSchema]}>
  <div class="container">
    <GuideHero
      eyebrow="Página pilar"
      title={title}
      description="Um mapa prático para abrir, organizar e fazer crescer um negócio nos EUA sem confundir empresa com status migratório, licença ou promessa de renda."
      primaryHref="#quem-pode-abrir-empresa"
      primaryLabel="Começar pelo essencial"
      secondaryHref={ENTREPRENEURSHIP_HUB_PATH}
      secondaryLabel="Explorar o hub"
      badges={["Empresa não legaliza sozinha", "LLC não substitui licença", "Impostos exigem registros", "Clientes exigem processo"]}
    />

    <GuideSummary
      items={[
        { label: "Para quem", value: "Brasileiros planejando, formalizando ou fazendo crescer um negócio nos EUA" },
        { label: "Escopo", value: "Empresa, documentos, operação, proteção, marketing e crescimento" },
        { label: "Atualização", value: "Revisado em 20 de julho de 2026" },
        { label: "Aviso", value: "Conteúdo informativo; não substitui orientação individual" }
      ]}
    />

    <section class="narrow-container article-content guide-article">
      <article>
        <PillarContent />
      </article>
    </section>

    <GuideOfficialSources sources={officialEntrepreneurshipSources} />

    <GuideCTA
      title="Continue pelo hub de empreendedorismo"
      description="Encontre os artigos especializados, a jornada por etapas e os próximos temas do cluster para brasileiros que querem construir negócios nos Estados Unidos."
      primaryHref={ENTREPRENEURSHIP_HUB_PATH}
      primaryLabel="Abrir hub de empreendedorismo"
      secondaryHref="/categorias/trabalho-renda.html"
      secondaryLabel="Ver trabalho e renda"
    />
  </div>
</BaseLayout>

<style>
  .guide-article {
    margin-top: 2rem;
  }
</style>
